/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #D40E61, #FF5C8D);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.user-info-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #fff;
}

.user-detail {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.nickname {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-type {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

/* 余额行 */
.balance-row {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.balance-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.balance-label {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.balance-amount {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.btn-recharge {
  background: #fff;
  color: #D40E61;
  font-size: 26rpx;
  font-weight: bold;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
}

/* 会员切换标签 */
.role-switch {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.role-tag {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #999;
}

.role-tag.active {
  background: linear-gradient(135deg, #D40E61, #FF5C8D);
  color: #fff;
  font-weight: bold;
}

/* 功能列表 */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 退出登录 */
.logout-item {
  background: #fff;
}

.logout-text {
  color: #999;
}

/* 登录按钮 */
.btn-login {
  width: 100%;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  padding: 28rpx 0;
}

.btn-login::after {
  border: none;
}
