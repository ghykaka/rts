/* pages/profile/profile.wxss */

.not-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.btn-login {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  width: 400rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}

.btn-login::after {
  border: none;
}

.tip {
  color: #999;
  font-size: 24rpx;
}

/* 用户信息 */
.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #D40E61, #FF5C8D);
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  min-height: 140rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #fff;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.nickname {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 40rpx;
}

.user-type {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  line-height: 40rpx;
}

.role-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.role-tag {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.3s;
}

.role-tag.active {
  background: #fff;
  color: #D40E61;
  font-weight: bold;
}

/* 余额 */
.balance-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.balance-card {
  flex: 1;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.balance-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.balance-card .label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.balance-card .amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #D40E61;
}

.btn-recharge {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-size: 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  width: 120rpx;
  margin-left: 20rpx;
}

.btn-recharge::after {
  border: none;
}

/* 企业Banner */
.enterprise-banner,
.enterprise-manage-banner,
.test-banner {
  background: linear-gradient(135deg, #FFF5F5, #FFE8EC);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.enterprise-manage-banner {
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.test-banner {
  background: #f0f0f0;
}

.test-banner .banner-title {
  color: #666;
}

.banner-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.banner-title {
  font-size: 30rpx;
  color: #D40E61;
  font-weight: bold;
}

.banner-desc {
  font-size: 24rpx;
  color: #999;
}

.banner-arrow {
  font-size: 40rpx;
  color: #D40E61;
  font-weight: bold;
}

/* 功能列表 */
.menu-list {
  background-color: #fff;
  border-radius: 12rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* 退出登录 */
.logout-item {
  margin-top: 20rpx;
  border-radius: 12rpx;
}

.menu-icon.logout-icon {
  opacity: 0.7;
}

.logout-text {
  color: #999;
}
