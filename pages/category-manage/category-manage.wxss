/* pages/category-manage/category-manage.wxss */

.container {
  height: 100vh;
  background: #f5f5f5;
  overflow-x: hidden;
  box-sizing: border-box;
}

.header {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.category-list {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.category-group {
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.category-item {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
  transition: transform 0.2s, opacity 0.2s;
}

.category-item.top-level {
  background: linear-gradient(135deg, #fff5f5, #fff);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.category-item.sub-level {
  background: #fff;
  padding: 20rpx 24rpx;
  margin-left: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.category-item.dragging {
  opacity: 0.8;
  transform: scale(1.02);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 1000;
}

.category-item.drag-over {
  border: 2rpx dashed #D40E61;
}

.category-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.drag-handle {
  font-size: 36rpx;
  color: #999;
  cursor: move;
  user-select: none;
  padding: 0 6rpx;
  flex-shrink: 0;
}

.category-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  font-weight: 500;
}

.category-actions {
  display: flex;
  align-items: center;
  gap: 15px;
  flex-shrink: 0;
}

.sort-btns {
  display: flex;
  flex-shrink: 0;
}

.sort-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.sort-btn.up {
  border-right: 1rpx solid #e5e5e5;
}

.sort-btn.disabled {
  color: #ccc;
  background: #fafafa;
}

.sort-btn:not(.disabled):active {
  background: #e5e5e5;
}

.category-item.sub-level .category-actions {
  display: flex;
  align-items: center;
  gap: 15px;
  flex-shrink: 0;
}

.category-item.sub-level .sort-btns {
  display: flex;
  flex-shrink: 0;
}

.category-item.sub-level .category-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: normal;
}

.action-btn {
  font-size: 22rpx;
  padding: 6rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.action-btn.add {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
}

.action-btn.edit {
  background: #f0f0f0;
  color: #666;
}

.action-btn.delete {
  background: #ffe5e5;
  color: #ff4d4f;
}

.sub-categories {
  margin-top: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(212, 14, 97, 0.4);
  z-index: 100;
}

.bottom-space {
  height: 160rpx;
  background: transparent;
}

.add-icon {
  font-size: 36rpx;
}
