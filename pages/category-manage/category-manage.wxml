<!--pages/category-manage/category-manage.wxml-->
<view class="container">
  <view class="header">
    <text class="title">分类管理</text>
  </view>

  <scroll-view class="category-list" scroll-y catchtouchmove="preventScroll">
    <view class="category-group" wx:for="{{categories}}" wx:key="_id">
      <!-- 一级分类 -->
      <view
        class="category-item top-level {{draggingId === item._id ? 'dragging' : ''}} {{dragOverId === item._id && draggingId !== item._id ? 'drag-over' : ''}}"
        data-id="{{item._id}}"
        data-level="top"
        data-parent-id=""
        data-index="{{index}}"
        bindlongpress="handleLongPress"
        catchtouchmove="handleTouchMove"
        catchtouchend="handleTouchEnd"
        catchtouchcancel="handleTouchCancel"
      >
        <view class="category-info">
          <text class="drag-handle">☰</text>
          <text class="category-name">{{item.name}}</text>
          <view class="category-actions">
            <text class="action-btn add" catchtap="addSubCategory" data-id="{{item._id}}" data-name="{{item.name}}">添加子分类</text>
            <text class="action-btn edit" catchtap="editCategory" data-id="{{item._id}}" data-name="{{item.name}}" data-parent-id="">编辑</text>
            <text class="action-btn delete" catchtap="deleteCategory" data-id="{{item._id}}" data-name="{{item.name}}">删除</text>
          </view>
        </view>
      </view>

      <!-- 二级分类 -->
      <view class="sub-categories" wx:if="{{item.children && item.children.length > 0}}">
        <view
          class="category-item sub-level {{draggingId === subItem._id ? 'dragging' : ''}} {{dragOverId === subItem._id && draggingId !== subItem._id ? 'drag-over' : ''}}"
          wx:for="{{item.children}}"
          wx:for-item="subItem"
          wx:key="_id"
          data-id="{{subItem._id}}"
          data-level="sub"
          data-parent-id="{{item._id}}"
          data-index="{{index}}"
          bindlongpress="handleLongPress"
          catchtouchmove="handleTouchMove"
          catchtouchend="handleTouchEnd"
          catchtouchcancel="handleTouchCancel"
        >
          <view class="category-info">
            <text class="drag-handle">☰</text>
            <text class="category-name">{{subItem.name}}</text>
            <view class="category-actions">
              <text class="action-btn edit" catchtap="editCategory" data-id="{{subItem._id}}" data-name="{{subItem.name}}" data-parent-id="{{item._id}}">编辑</text>
              <text class="action-btn delete" catchtap="deleteCategory" data-id="{{subItem._id}}" data-name="{{subItem.name}}">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{categories.length === 0 && !loading}}">
      <text>暂无分类</text>
    </view>

    <!-- 底部占位空间 -->
    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="addTopCategory">
    <text class="add-icon">+</text>
    <text>添加一级分类</text>
  </view>
</view>
