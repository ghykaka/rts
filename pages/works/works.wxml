<!--pages/works/works.wxml-->
<view class="container">
  <!-- 提示 -->
  <view class="tip">生成作品有线上保存期限，请及时保存到本地</view>

  <!-- Tab -->
  <view class="tabs">
    <view
      class="tab {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="index"
      bindtap="switchTab"
      data-index="{{index}}"
    >
      {{item}}
      <view class="tab-badge" wx:if="{{getTabBadge(index) > 0}}">{{getTabBadge(index)}}</view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view
      class="order-item"
      wx:for="{{orderList}}"
      wx:key="_id"
      bindtap="viewOrderDetail"
      data-item="{{item}}"
    >
      <!-- 生成中的订单 -->
      <view wx:if="{{item.status === 'generating'}}" class="order-pending">
        <view class="pending-icon">
          <text class="icon-text">⏳</text>
        </view>
        <view class="pending-info">
          <text class="pending-title">{{item.product_name}} + {{item.template_name}}</text>
          <text class="pending-time">{{item.displayTime}}</text>
          <text class="pending-desc">AI正在为您生成作品，请耐心等待</text>
          <view class="progress-bar">
            <view class="progress-inner"></view>
          </view>
        </view>
      </view>

    <!-- 已完成的订单 -->
    <view wx:if="{{item.status === 'completed'}}" class="order-completed">
      <image
        class="output-image"
        src="{{item.poster_url || item.template_cover}}"
        mode="aspectFill"
      />
      <view class="completed-info">
        <text class="completed-title">{{item.product_name}} + {{item.template_name}}</text>
        <view class="completed-meta">
          <text class="time">{{item.displayTime}}</text>
          <text class="price">¥{{item.displayPrice}}</text>
        </view>
      </view>
    </view>

      <!-- 失败的订单 -->
      <view wx:if="{{item.status === 'failed'}}" class="order-failed">
        <view class="failed-icon">❌</view>
        <view class="failed-info">
          <text class="failed-title">{{item.product_name}} + {{item.template_name}}</text>
          <text class="failed-time">{{item.displayTime}}</text>
          <text class="failed-desc">生成过程中出现错误，请重试</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{orderList.length === 0 && !loading}}">
      <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
      <text class="empty-text">暂时空空如也</text>
      <text class="empty-tip" bindtap="goHome">去创作</text>
    </view>

    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
