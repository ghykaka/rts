/* pages/works/works.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

.tip {
  background: #FFF9E6;
  color: #FFA940;
  font-size: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

/* Tab */
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  border-radius: 2rpx;
}

.tab-badge {
  position: absolute;
  top: 12rpx;
  right: 20%;
  min-width: 32rpx;
  height: 32rpx;
  background: #D40E61;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #333;
  font-weight: bold;
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-item {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 生成中 */
.order-pending {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.pending-icon {
  width: 80rpx;
  height: 80rpx;
  background: #E6F7FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-text {
  font-size: 36rpx;
}

.pending-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pending-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.pending-time {
  font-size: 22rpx;
  color: #999;
}

.pending-desc {
  font-size: 24rpx;
  color: #D40E61;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #FFF5F5;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-inner {
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  animation: progress 1.5s ease-in-out infinite;
}

@keyframes progress {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(200%); }
}

/* 已完成 */
.order-completed {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.output-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}

.completed-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  justify-content: space-between;
}

.completed-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.completed-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.completed-meta .time {
  font-size: 24rpx;
  color: #999;
}

.completed-meta .price {
  font-size: 32rpx;
  color: #D40E61;
  font-weight: bold;
}

/* 失败 */
.order-failed {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
  align-items: center;
}

.failed-icon {
  width: 80rpx;
  height: 80rpx;
  background: #FFF0F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 36rpx;
}

.failed-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.failed-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.failed-time {
  font-size: 22rpx;
  color: #999;
}

.failed-desc {
  font-size: 24rpx;
  color: #D40E61;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.empty-tip {
  font-size: 26rpx;
  color: #D40E61;
  padding: 12rpx 40rpx;
  background: linear-gradient(135deg, #FFF5F5, #FFE8EC);
  border-radius: 24rpx;
  margin-top: 20rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}
