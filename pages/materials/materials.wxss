/* pages/materials/materials.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 未登录提示 */
.not-login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 60rpx 40rpx;
}

.tip-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
  margin-bottom: 40rpx;
}

.tip-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tip-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 60rpx;
}

.tip-btn {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  padding: 24rpx 80rpx;
}

.tip-btn::after {
  border: none;
}

/* 分类头部（编辑按钮） */
.category-header {
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-tip {
  flex: 1;
  font-size: 22rpx;
  color: #a83153;
  line-height: 1.4;
  margin-right: 16rpx;
}

.edit-category-btn {
  padding: 12rpx 24rpx;
  background-color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
}

/* 顶部一级分类 */
.top-categories {
  background-color: #fff;
  padding: 20rpx 0 20rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-scroll {
  white-space: nowrap;
  flex: 1;
  width: 100%;
}

.top-category-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.top-category-item:first-child {
  margin-left: 0;
}

.top-category-item.active {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
}

.edit-category-btn {
  padding: 12rpx 24rpx;
  margin-left: 16rpx;
  margin-right: 16rpx;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

/* 内容区域 */
.content-wrapper {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧二级分类 */
.side-categories {
  width: 180rpx;
  background-color: #f7f7f7;
  height: 100%;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.side-category-item {
  padding: 24rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
  background-color: #fff;
}

.side-category-item.active {
  color: #D40E61;
  background-color: #fff;
  font-weight: bold;
  border-left: 4rpx solid #D40E61;
}

.empty-sub {
  padding: 40rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 右侧素材列表 */
.materials-container {
  flex: 1;
  height: 100%;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.current-category-name {
  background-color: #fff;
  padding: 24rpx 20rpx;
  font-size: 26rpx;
  color: #999;
  border-bottom: 1rpx solid #f5f5f5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.material-grid {
  padding: 0;
}

/* 分类标题 */
.category-section-header {
  padding: 24rpx 20rpx;
  font-size: 26rpx;
  color: #999;
  border-bottom: 1rpx solid #f5f5f5;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #f5f5f5;
}

.material-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.material-item .image-wrapper,
.material-item .video-wrapper {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
  background-color: #fff;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.material-item .image-wrapper image,
.material-item .video-wrapper video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.material-item .content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.material-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.material-actions {
  display: flex;
  gap: 32rpx;
}

.material-action {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 28rpx;
  line-height: 1;
}

.upload-btn {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(212, 14, 97, 0.4);
  z-index: 100;
}

.upload-btn text {
  font-size: 60rpx;
  line-height: 1;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.empty-text {
  font-size: 28rpx;
}

.empty-btn {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  line-height: 1;
}

.empty-btn::after {
  border: none;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  transition: transform 0.2s ease;
}

.content-keyboard-up {
  transform: translateY(-120rpx);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom:1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-wrapper {
  position: relative;
  width: 100%;
}

.input-wrapper .form-input {
  padding-right: 80rpx;
}

.input-clear {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

.picker {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  border: none;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #f5f5f5;
}

.modal-btn.confirm {
  color: #D40E61;
  font-weight: bold;
}

.modal-btn::after {
  border: none;
}

.form-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
}

.selected-category-display {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
}

.selected-category-label {
  color: #999;
  margin-right: 10rpx;
}

.selected-category-value {
  color: #333;
  font-weight: 500;
}

/* 分类选择器 */
.category-picker-wrapper {
  display: flex;
  height: 400rpx;
  border: 1rpx solid #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.category-picker-left,
.category-picker-right {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.category-picker-left {
  background-color: #f7f7f7;
  border-right: 1rpx solid #f5f5f5;
}

.category-picker-scroll {
  flex: 1;
  height: 100%;
}

.picker-category-item {
  padding: 24rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
  transition: all 0.3s;
}

.picker-category-item.active {
  color: #D40E61;
  background-color: #fff;
  font-weight: bold;
}

.category-picker-left .picker-category-item.active {
  background-color: #fff;
  border-left: 4rpx solid #D40E61;
}

.empty-picker {
  padding: 40rpx;
  font-size: 26rpx;
  color: #999;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}


