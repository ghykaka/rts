/* pages/category-edit/category-edit.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.form-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.parent-category {
  font-size: 28rpx;
  color: #666;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.level-tag {
  font-size: 24rpx;
  color: #D40E61;
  padding: 12rpx 24rpx;
  background: #fff5f5;
  border-radius: 20rpx;
  display: inline-block;
}

.save-btn {
  margin-top: 40rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.save-btn::after {
  border: none;
}
