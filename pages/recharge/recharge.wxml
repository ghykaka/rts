<!--pages/recharge/recharge.wxml-->
<view class="container">
  <view class="title">{{pageTitle}}</view>
  <view class="company-name-row" wx:if="{{isEnterpriseAdmin && companyName}}">
    <text class="company-name">{{companyName}}</text>
  </view>

  <view class="amount-section">
    <text class="label">选择金额</text>
    <view class="amount-grid">
      <view 
        class="amount-item {{selectedConfigId === item._id ? 'active' : ''}}"
        wx:for="{{configList}}"
        wx:key="_id"
        bindtap="selectAmount"
        data-id="{{item._id}}"
        data-amount="{{item.amount}}"
        data-bonus="{{item.bonus}}"
      >
        <view class="amount-top">
          <text class="amount">¥{{item.amount}}</text>
          <text class="bonus-tag" wx:if="{{item.bonus > 0}}">送{{item.bonus}}</text>
        </view>
        <text class="amount-tip" wx:if="{{item.bonus > 0}}">到账{{item.amount + item.bonus}}元</text>
      </view>
    </view>
  </view>

  <view class="balance-row">
    <text>当前积分：{{balance}}</text>
  </view>

  <view 
    class="btn-recharge {{paying ? 'paying' : ''}} {{configLoading || !selectedConfigId ? 'disabled' : ''}}" 
    bindtap="virtualRecharge"
  >
    <text wx:if="{{paying}}">支付中...</text>
    <text wx:elif="{{configLoading}}">加载中...</text>
    <text wx:elif="{{!selectedConfigId}}">暂无可用充值选项</text>
    <text wx:else>微信支付 ¥{{selectedAmount}}</text>
  </view>

  <view class="tips">
    <text>充值金额将转换为积分，1元 = 100积分</text>
  </view>
</view>
