/* pages/recharge/recharge.wxss */

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.company-name-row {
  text-align: center;
  padding-bottom: 20rpx;
}

.company-name {
  font-size: 28rpx;
  color: #666;
}

.amount-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.amount-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.amount-item {
  width: calc(33.33% - 14rpx);
  padding: 20rpx 0;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  position: relative;
}

.amount-item.active {
  background-color: #07c160;
}

.amount-top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.amount-item .amount {
  font-size: 32rpx;
  font-weight: bold;
}

.amount-item.active .amount {
  color: #fff;
}

.bonus-tag {
  font-size: 18rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  position: absolute;
  top: -12rpx;
  right: -8rpx;
  white-space: nowrap;
}

.amount-tip {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.amount-item.active .amount-tip {
  color: rgba(255, 255, 255, 0.8);
}

.btn-recharge {
  background-color: #07c160;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin: 0 30rpx;
  transition: opacity 0.15s, transform 0.1s;
}

.btn-recharge:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.btn-recharge.paying {
  background-color: #a5d6a7;
  color: #fff;
}

.btn-recharge.disabled {
  background-color: #ccc;
  color: #fff;
}

.balance-row {
  text-align: center;
  padding: 20rpx 0;
  color: #666;
  font-size: 28rpx;
}

.tips {
  text-align: center;
  padding: 20rpx 0;
  color: #999;
  font-size: 24rpx;
}
