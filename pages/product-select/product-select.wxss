/* pages/product-select/product-select.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* Step标题 */
.step-title {
  padding: 30rpx 20rpx 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: #fff;
  margin-bottom: 2rpx;
}

/* 未登录提示 - 放在筛选区域下方 */
.login-tip {
  background: #f5f5f5;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-line {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: center;
}

.tip-line.highlight {
  color: #D40E61;
  font-weight: bold;
  font-size: 30rpx;
  margin: 20rpx 0 30rpx;
}

.login-btn {
  width: 280rpx;
  height: 80rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.login-btn::after {
  border: none;
}

/* 顶部信息区域 */
.header-section {
  background: #fff;
  padding: 20rpx;
  margin-bottom: 2rpx;
  display: flex;
  gap: 20rpx;
}

.template-preview {
  flex: 1;
  display: flex;
  gap: 20rpx;
  min-width: 0;
}

.template-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #eee;
  flex-shrink: 0;
}

.template-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.template-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.template-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 筛选区域 - 复用模板列表样式 */
.filter-section {
  background: #fff;
  padding: 20rpx 20rpx;
  margin-bottom: 2rpx;
}

.sub-category-section {
  background: #fff;
  padding: 16rpx 20rpx;
  margin-bottom: 2rpx;
}

.filter-scroll-full {
  width: 100%;
  white-space: nowrap;
}

.filter-tags {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 20rpx;
}

.filter-tag {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
  white-space: nowrap;
}

.filter-tag.small {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
}

.filter-tag.active {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-weight: 500;
}

/* 瀑布流容器 - 3列 */
.waterfall-container {
  display: flex;
  padding: 20rpx 0;
  gap: 16rpx;
  box-sizing: border-box;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-width: 0;
}

/* 产品卡片 */
.product-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: visible;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

/* 图片容器 - 白色正方形 */
.product-image-wrapper {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #fff;
  display: block;
  overflow: hidden;
  border-radius: 12rpx 12rpx 0 0;
}

.product-image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: contain;
  background: #fff;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 24rpx;
  color: #000;
  font-weight: bold;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-icon {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
}

.select-icon.active {
  border-color: #D40E61;
  background: #D40E61;
  color: #fff;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 26rpx;
}

/* 底部按钮 */
.footer-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.next-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.next-btn::after {
  border: none;
}
