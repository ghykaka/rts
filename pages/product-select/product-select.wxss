/* pages/product-select/product-select.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* Step标题 */
.step-title {
  padding: 30rpx 20rpx 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: #fff;
  margin-bottom: 20rpx;
}

/* 顶部信息区域 */
.header-section {
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
}

.template-preview {
  flex: 1;
  display: flex;
  gap: 20rpx;
  min-width: 0;
}

.template-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #eee;
  flex-shrink: 0;
}

.template-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.template-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.template-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 素材库切换 */
.lib-switch {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 2rpx;
}

.switch-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 36rpx;
}

.switch-btn.active {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-weight: bold;
}

/* 分类标签栏 */
.category-tabs {
  display: flex;
  padding: 0 20rpx 20rpx;
  background: #fff;
  overflow-x: auto;
}

.primary-tabs {
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #eee;
}

.secondary-tabs {
  background: #fafafa;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  margin-right: 20rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.tab-item.active {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-weight: 500;
}

/* 产品网格容器 */
.waterfall-container {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 16rpx;
  box-sizing: border-box;
}

/* 产品卡片 */
.product-card {
  width: calc((100% - 32rpx) / 3);
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.product-image-wrapper {
  width: 100%;
  height: 220rpx;
  background: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.product-image {
  width: auto;
  height: 100%;
  display: block;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 24rpx;
  color: #000;
  font-weight: bold;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-icon {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
}

.select-icon.active {
  border-color: #D40E61;
  background: #D40E61;
  color: #fff;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 26rpx;
}

/* 底部按钮 */
.footer-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.next-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.next-btn::after {
  border: none;
}
