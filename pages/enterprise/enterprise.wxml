<!--pages/enterprise/enterprise.wxml-->
<view class="container">
  <!-- Tab -->
  <view class="tabs">
    <view 
      class="tab {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="index"
      bindtap="switchTab"
      data-index="{{index}}"
    >
      {{item}}
    </view>
  </view>

  <!-- 素材网格 -->
  <view class="material-grid">
    <view class="material-item" wx:for="{{materials}}" wx:key="_id">
      <image src="{{item.url}}" mode="aspectFill" />
    </view>
  </view>

  <!-- 上传按钮 -->
  <view class="upload-btn" bindtap="uploadMaterial">
    <text>+</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{materials.length === 0 && !loading}}">
    <text>暂无素材</text>
    <button size="mini" bindtap="uploadMaterial">去添加</button>
  </view>
</view>
