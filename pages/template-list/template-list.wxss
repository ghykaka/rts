/* pages/template-list/template-list.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 40rpx 0;
}

/* Step标题 */
.step-title {
  padding: 30rpx 20rpx 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: #fff;
  margin-bottom: 20rpx;
}

/* 筛选区域 */
.filter-section {
  background: #fff;
  padding: 20rpx 20rpx;
  margin-bottom: 2rpx;
}

.sub-category-section {
  background: #fff;
  padding: 16rpx 20rpx;
  margin-bottom: 2rpx;
}

.filter-row {
  display: flex;
  align-items: flex-start;
  padding: 0 20rpx;
}

.filter-label {
  width: 60rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-scroll-full {
  width: 100%;
  white-space: nowrap;
}

.filter-tags {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 20rpx;
}

.filter-tag {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
  white-space: nowrap;
}

.filter-tag.small {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
}

.filter-tag.active {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-weight: 500;
}

.filter-tag.owned {
  color: #333;
}

.filter-tag.more {
  color: #999;
  font-size: 24rpx;
}

/* 二级分类行 */
.sub-row {
  margin-top: 16rpx;
}

/* 顶部分类标签栏 */
.category-tabs {
  display: flex;
  padding: 0 20rpx 20rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  overflow-x: auto;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  margin-right: 20rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.tab-item.active {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-weight: 500;
}

/* 瀑布流容器 - 3列 */
.waterfall-container {
  display: flex;
  padding: 20rpx 20rpx;
  gap: 16rpx;
  box-sizing: border-box;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-width: 0;
}

/* 模板卡片 */
.template-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.template-image {
  width: 100%;
  display: block;
  background: #eee;
}

.template-info {
  padding: 16rpx;
}

.template-title {
  font-size: 24rpx;
  color: #000;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.template-category {
  font-size: 18rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-function {
  font-size: 18rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 26rpx;
}
