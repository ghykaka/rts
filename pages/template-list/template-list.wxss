/* pages/template-list/template-list.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* Step标题 */
.step-title {
  padding: 30rpx 20rpx 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: #fff;
  margin-bottom: 20rpx;
}

/* 顶部分类标签栏 */
.category-tabs {
  display: flex;
  padding: 0 20rpx 20rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  overflow-x: auto;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  margin-right: 20rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.tab-item.active {
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-weight: 500;
}

/* 瀑布流容器 - 3列 */
.waterfall-container {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 模板卡片 */
.template-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.template-image {
  width: 100%;
  display: block;
  background: #eee;
}

.template-info {
  padding: 16rpx;
}

.template-title {
  font-size: 24rpx; /* 12px */
  color: #000;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-category {
  font-size: 20rpx; /* 10px */
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 26rpx;
}
