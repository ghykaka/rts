<!--pages/template-list/template-list.wxml-->
<view class="container">
  <!-- Step标题 -->
  <view class="step-title" wx:if="{{functionName}}">{{functionName}} - 选择模板</view>
  <view class="step-title" wx:else>选择模板</view>

  <!-- 行业筛选行 -->
  <view class="filter-section">
    <scroll-view class="filter-scroll-full" scroll-x>
      <view class="filter-tags">
        <!-- 全部 -->
        <view
          class="filter-tag {{currentIndustry === '' ? 'active' : ''}}"
          bindtap="selectIndustry"
          data-industry=""
        >
          全部
        </view>
        <!-- 企业行业（已登录企业用户） -->
        <view
          class="filter-tag {{currentIndustry === item ? 'active' : ''}}"
          bindtap="selectIndustry"
          data-industry="{{item}}"
          wx:for="{{userIndustries}}"
          wx:key="*this"
        >
          {{item}}
        </view>
        <!-- 其他行业（排除企业行业） -->
        <view
          class="filter-tag {{currentIndustry === item.name ? 'active' : ''}}"
          bindtap="selectIndustry"
          data-industry="{{item.name}}"
          wx:for="{{otherIndustries}}"
          wx:key="_id"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 分类筛选行 - 一级分类 -->
  <view class="filter-section category-section" wx:if="{{categories.length > 0}}">
    <scroll-view class="filter-scroll-full" scroll-x>
      <view class="filter-tags">
        <view
          class="filter-tag {{currentCategory1 === '' ? 'active' : ''}}"
          bindtap="selectCategory1"
          data-id=""
        >
          全部
        </view>
        <view
          class="filter-tag {{currentCategory1 === item._id ? 'active' : ''}}"
          bindtap="selectCategory1"
          data-id="{{item._id}}"
          wx:for="{{categories}}"
          wx:key="_id"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 二级分类筛选行（独立一行，点击一级分类后显示） -->
  <view class="filter-section sub-category-section" wx:if="{{currentCategory1 && subCategories.length > 0}}">
    <scroll-view class="filter-scroll-full" scroll-x>
      <view class="filter-tags">
        <view
          class="filter-tag small {{currentCategory2 === '' ? 'active' : ''}}"
          bindtap="selectCategory2"
          data-id=""
        >
          全部
        </view>
        <view
          class="filter-tag small {{currentCategory2 === item._id ? 'active' : ''}}"
          bindtap="selectCategory2"
          data-id="{{item._id}}"
          wx:for="{{subCategories}}"
          wx:key="_id"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 模板瀑布流 - 3列 -->
  <view class="waterfall-container" wx:if="{{templates.length > 0}}">
    <!-- 第0列 -->
    <view class="waterfall-column">
      <view
        class="template-card"
        wx:for="{{column0}}"
        wx:key="_id"
        bindtap="selectTemplate"
        data-id="{{item._id}}"
        data-name="{{item.templateName}}"
        data-cover="{{item.thumbnail}}"
        data-description="{{item.templateDesc}}"
        data-needmaterial="{{item.needMaterial}}"
        data-functionid="{{item.functionIds && item.functionIds.length > 0 ? item.functionIds[0] : item.functionId}}"
        data-functionids="{{item.functionIds || (item.functionId ? [item.functionId] : [])}}"
      >
        <image
          class="template-image"
          src="{{item.thumbnail || '/assets/icons/default-cover.png'}}"
          mode="widthFix"
          lazy-load
          data-column="0"
          data-index="{{index}}"
          bindload="onImageLoad"
        />
        <view class="template-info">
          <text class="template-title">{{item.templateName}}</text>
          <view class="template-tags">
            <text class="template-category" wx:if="{{item.category1Name || item.industry}}">{{item.category1Name || item.industry}}</text>
            <text class="template-function" wx:if="{{item.functionName}}">{{item.functionName}}</text>
            <text class="template-function-multi" wx:if="{{item.functionIds && item.functionIds.length > 1}}">+{{item.functionIds.length - 1}}</text>
          </view>
        </view>
      </view>
    </view>
    <!-- 第1列 -->
    <view class="waterfall-column">
      <view
        class="template-card"
        wx:for="{{column1}}"
        wx:key="_id"
        bindtap="selectTemplate"
        data-id="{{item._id}}"
        data-name="{{item.templateName}}"
        data-cover="{{item.thumbnail}}"
        data-description="{{item.templateDesc}}"
        data-needmaterial="{{item.needMaterial}}"
        data-functionid="{{item.functionIds && item.functionIds.length > 0 ? item.functionIds[0] : item.functionId}}"
        data-functionids="{{item.functionIds || (item.functionId ? [item.functionId] : [])}}"
      >
        <image
          class="template-image"
          src="{{item.thumbnail || '/assets/icons/default-cover.png'}}"
          mode="widthFix"
          lazy-load
          data-column="1"
          data-index="{{index}}"
          bindload="onImageLoad"
        />
        <view class="template-info">
          <text class="template-title">{{item.templateName}}</text>
          <view class="template-tags">
            <text class="template-category" wx:if="{{item.category1Name || item.industry}}">{{item.category1Name || item.industry}}</text>
            <text class="template-function" wx:if="{{item.functionName}}">{{item.functionName}}</text>
            <text class="template-function-multi" wx:if="{{item.functionIds && item.functionIds.length > 1}}">+{{item.functionIds.length - 1}}</text>
          </view>
        </view>
      </view>
    </view>
    <!-- 第2列 -->
    <view class="waterfall-column">
      <view
        class="template-card"
        wx:for="{{column2}}"
        wx:key="_id"
        bindtap="selectTemplate"
        data-id="{{item._id}}"
        data-name="{{item.templateName}}"
        data-cover="{{item.thumbnail}}"
        data-description="{{item.templateDesc}}"
        data-needmaterial="{{item.needMaterial}}"
        data-functionid="{{item.functionIds && item.functionIds.length > 0 ? item.functionIds[0] : item.functionId}}"
        data-functionids="{{item.functionIds || (item.functionId ? [item.functionId] : [])}}"
      >
        <image
          class="template-image"
          src="{{item.thumbnail || '/assets/icons/default-cover.png'}}"
          mode="widthFix"
          lazy-load
          data-column="2"
          data-index="{{index}}"
          bindload="onImageLoad"
        />
        <view class="template-info">
          <text class="template-title">{{item.templateName}}</text>
          <view class="template-tags">
            <text class="template-category" wx:if="{{item.category1Name || item.industry}}">{{item.category1Name || item.industry}}</text>
            <text class="template-function" wx:if="{{item.functionName}}">{{item.functionName}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{templates.length === 0 && !loading}}" class="empty">
    <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
    <text class="empty-text">暂无模板</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{hasMore && !loading && templates.length > 0}}" class="load-more" bindtap="onReachBottom">
    <text>加载更多</text>
  </view>
</view>
