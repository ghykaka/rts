/* pages/sub-accounts/sub-accounts.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 企业信息卡片 */
.enterprise-card {
  background: linear-gradient(135deg, #D40E61, #FF5C8D);
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(212, 14, 97, 0.3);
}

.enterprise-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.company-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.nickname {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.balance-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.card-balance-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.balance-value {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn::after {
  border: none;
}

.test-btn {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  color: #999;
  border: 1rpx solid #ddd;
  border-radius: 40rpx;
  font-size: 26rpx;
  margin-bottom: 30rpx;
}

.test-btn::after {
  border: none;
}

.account-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.account-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.account-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eee;
}

.info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
}

.name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.phone {
  font-size: 24rpx;
  color: #999;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.status-tag.active {
  background: #e8f5e9;
  color: #4caf50;
}

.status-tag.pending {
  background: #fff3e0;
  color: #ff9800;
}

.remark {
  font-size: 24rpx;
  color: #666;
}

.remark-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.remark-link {
  font-size: 24rpx;
  color: #D40E61;
  margin-left: 16rpx;
}

.edit-remark-btn {
  background: transparent;
  color: #666;
  font-size: 12rpx;
  margin-left: 16rpx;
  padding: 2rpx 8rpx;
  height: 36rpx;
  line-height: 32rpx;
}

.edit-remark-btn::after {
  border: none;
}

.balance-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.balance-label {
  font-size: 22rpx;
  color: #999;
}

.balance-amount {
  font-size: 32rpx;
  color: #D40E61;
  font-weight: bold;
}

.allocate-btn {
  margin-top: 8rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-size: 22rpx;
}

.allocate-btn::after {
  border: none;
}

.action-btns {
  display: flex;
  gap: 8rpx;
}

.delete-btn {
  margin-top: 8rpx;
  background: #f5f5f5;
  color: #999;
  font-size: 22rpx;
}

.delete-btn::after {
  border: 1rpx solid #ddd;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

.test-tip {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 16rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  transition: transform 0.2s ease;
}

.content-keyboard-up {
  transform: translateY(-120rpx);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.current-balance {
  color: #D40E61;
  font-weight: bold;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-tip {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.allocate-amount {
  color: #D40E61;
  font-weight: bold;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border: none;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #f5f5f5;
}

.modal-btn.confirm {
  color: #D40E61;
  font-weight: bold;
}

.modal-btn::after {
  border: none;
}
