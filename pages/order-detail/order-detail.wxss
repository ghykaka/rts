/* pages/order-detail/order-detail.wxss */
.order-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 加载中 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f5f5f5;
  border-top-color: #D40E61;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 详情内容 */
.detail-content {
  padding-bottom: 40rpx;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-pending, .status-processing {
  background: #FFF3E6;
  color: #FF9500;
}

.status-completed {
  background: #E8F8E8;
  color: #52C41A;
}

.status-failed {
  background: #FFF0F0;
  color: #FF4D4F;
}

/* 信息项 */
.info-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.info-value.price {
  color: #D40E61;
  font-weight: bold;
  font-size: 30rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 用时显示 */
.duration {
  color: #999;
  font-size: 22rpx;
  white-space: nowrap;
}

/* 时间行（同一行显示完成时间和用时） */
.time-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 素材图 */
.material-image {
  max-width: 300rpx;
  border-radius: 8rpx;
}

/* 参数图片（60x60正方形） */
.param-image {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
}

/* 缩略图 */
.thumb-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

/* 输出结果 */
.result-card {
  background: linear-gradient(135deg, #fff, #FFF8FA);
}

.output-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.output-item {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 16rpx;
}

.output-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.output-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.output-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #D40E61;
  padding: 12rpx 28rpx;
  background: #FFF0F3;
  border-radius: 10rpx;
}

.output-image-wrap {
  width: 100%;
  border-radius: 8rpx;
  overflow: hidden;
}

.output-image {
  width: 100%;
  display: block;
}

.output-video-wrap {
  width: 100%;
  border-radius: 8rpx;
  overflow: hidden;
  background: #000;
}

.output-video {
  width: 100%;
  display: block;
}

.output-text {
  background: #f9f9f9;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 生成中提示 */
.processing-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.tip-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #D40E61;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

/* 失败提示 */
.error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: #FFF5F5;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.error-title {
  font-size: 30rpx;
  color: #FF4D4F;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.error-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 24rpx;
  text-align: center;
}

.retry-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: #999;
  font-size: 28rpx;
}
