<!--pages/index/index.wxml-->
<view class="container">
  <!-- 动态渲染首页配置组件 -->
  <block wx:for="{{homeConfigs}}" wx:key="_id">
    
    <!-- 用户信息组件 -->
    <view wx:if="{{item.componentType === 'userInfo' || item.componentType === '用户信息'}}" class="user-bar" bindtap="goProfile">
      <block wx:if="{{isLogin}}">
        <view class="user-info">
          <image
            class="avatar"
            src="{{userInfo.avatar || '/assets/icons/default-avatar.png'}}"
            mode="aspectFill"
          />
          <view class="info">
            <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
            <text class="balance">余额：¥{{displayBalance}}</text>
            <text class="balance" wx:if="{{isSubAccount}}">企业额度：¥{{displayEnterpriseBalance}}</text>
          </view>
        </view>
        <view class="recharge-btn" catchtap="goRecharge">
          <text>充值</text>
        </view>
      </block>
      <view class="login-only" wx:if="{{!isLogin}}">
        <text class="login-tip-text">登录后享受更多功能</text>
        <button class="login-btn" bindtap="wxLogin">登录 / 注册</button>
      </view>
    </view>
    
    <!-- 轮播图组件 -->
    <view wx:if="{{item.componentType === 'banner' || item.componentType === '轮播图'}}" class="banner-section">
      <swiper
        class="banner-swiper"
        indicator-dots="{{item.items && item.items.length > 1}}"
        autoplay="{{item.items && item.items.length > 1}}"
        interval="3000"
        circular="{{item.items && item.items.length > 1}}"
        indicator-color="rgba(255,255,255,0.5)"
        indicator-active-color="#fff"
        style="height: {{(item.params && item.params.height) || 320}}rpx;"
      >
        <swiper-item wx:for="{{item.items}}" wx:for-item="banner" wx:key="index">
          <image
            class="banner-image"
            src="{{banner.image}}"
            mode="aspectFill"
            bindtap="goFunctionPage"
            data-url="{{banner.linkValue}}"
          />
        </swiper-item>
      </swiper>
    </view>

    <!-- 金刚区入口组件 -->
    <view wx:if="{{(item.componentType === 'iconGrid' || item.componentType === '金刚区') && item.items.length > 0}}" class="icon-grid-section">
      <view wx:if="{{item.title}}" class="section-title">{{item.title}}</view>
      <view class="icon-grid">
        <view
          class="icon-item"
          wx:for="{{item.items}}"
          wx:for-item="icon"
          wx:key="index"
          bindtap="goFunctionPage"
          data-id="{{icon.linkValue}}"
          data-name="{{icon.title}}"
          data-linktype="{{icon.linkType}}"
        >
          <view class="icon-img-wrap">
            <image class="icon-img" src="{{icon.image}}" mode="aspectFit" />
          </view>
          <text class="icon-name">{{icon.title}}</text>
        </view>
      </view>
    </view>

    <!-- 图片网格组件 -->
    <view wx:if="{{(item.componentType === 'imageGrid' || item.componentType === '图片网格') && item.items.length > 0}}" class="image-grid-section">
      <view class="image-grid" style="columns: {{(item.params && item.params.columns) || 2}};">
        <view
          class="image-grid-item"
          wx:for="{{item.items}}"
          wx:for-item="img"
          wx:key="index"
          bindtap="goFunctionPage"
          data-id="{{img.linkValue}}"
          data-name="{{img.title}}"
        >
          <image class="grid-img" src="{{img.image}}" mode="widthFix" />
        </view>
      </view>
    </view>

    <!-- 瀑布流组件 -->
    <view wx:if="{{item.componentType === 'waterfall' || item.componentType === '瀑布流'}}" class="waterfall-section">
      <view wx:if="{{item.title}}" class="section-title">{{item.title}}</view>
      <view class="waterfall-grid">
        <view
          class="waterfall-item"
          wx:for="{{item.templates}}"
          wx:for-item="tpl"
          wx:key="_id"
          bindtap="goTemplateDetail"
          data-id="{{tpl._id}}"
          data-name="{{tpl.templateName || tpl.name}}"
          data-cover="{{tpl.thumbnail || tpl.originalImage}}"
          data-desc="{{tpl.templateDesc || tpl.description || ''}}"
          data-needmaterial="{{tpl.needMaterial}}"
          data-functionid="{{tpl.functionId}}"
        >
          <image
            class="waterfall-cover"
            src="{{tpl.thumbnail || tpl.originalImage || '/assets/icons/default-cover.png'}}"
            mode="widthFix"
          />
          <view class="waterfall-info">
            <text class="waterfall-name">{{tpl.templateName || tpl.name}}</text>
            <view class="waterfall-tags">
              <text class="waterfall-category" wx:if="{{tpl.categoryPath}}">{{tpl.categoryPath}}</text>
              <text class="waterfall-function" wx:if="{{tpl.functionName}}">{{tpl.functionName}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 瀑布流空状态 -->
      <view class="empty" wx:if="{{!item.templates || item.templates.length === 0}}">
        <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
        <text class="empty-text">暂无推荐模板</text>
      </view>
    </view>

  </block>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
