/* pages/index/index.wxss */

.container {
  padding-bottom: 120rpx;
  padding-left: 0;
  padding-right: 0;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f0f0f0;
  border: 2rpx solid #eee;
}

.info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.balance {
  font-size: 26rpx;
  color: #666;
}

.recharge-btn {
  padding: 12rpx 32rpx;
  background: #FF2C6D;
  color: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: bold;
}

/* 登录状态 */
.login-only {
  width: 100%;
  background: #fff;
}

.login-only .login-tip-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
  text-align: center;
}

.login-only .login-btn {
  width: 100%;
  background: #FF2C6D;
  color: #fff;
  border: none;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 44rpx;
  padding: 20rpx 0;
}

.login-only .login-btn::after {
  border: none;
}

/* 轮播图 */
.banner-section {
  padding: 0 20rpx 20rpx;
}

.banner-swiper {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 金刚区 */
.icon-grid-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.icon-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.icon-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.icon-img-wrap {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 12rpx;
}

.icon-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.icon-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 图片网格 */
.image-grid-section {
  padding: 0 20rpx 20rpx;
}

.image-grid {
  column-gap: 16rpx;
}

.image-grid-item {
  break-inside: avoid;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
}

.grid-img {
  width: 100%;
  display: block;
}

.grid-title {
  padding: 12rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
  background: #fff;
}

/* 瀑布流 */
.waterfall-section {
  padding: 0 20rpx 20rpx;
}

.waterfall-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.waterfall-item {
  width: calc(50% - 8rpx);
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.waterfall-cover {
  width: 100%;
  display: block;
  background-color: #f0f0f0;
}

.waterfall-info {
  padding: 16rpx;
}

.waterfall-name {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.waterfall-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.waterfall-category {
  font-size: 20rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.waterfall-function {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
