/* pages/index/index.wxss */

.container {
  padding-bottom: 120rpx;
  padding-left: 0;
  padding-right: 0;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部头图 */
.header-image {
  width: 100%;
  display: block;
  margin-bottom: 20rpx;
}

/* 快捷入口 */
.quick-entry {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.entry-icon text {
  font-size: 44rpx;
}

.entry-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.user-bar-overlap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  margin: -50rpx 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.balance {
  font-size: 24rpx;
  color: #D40E61;
}

.recharge-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
}

/* 轮播图 */
.banner {
  height: 320rpx;
  margin: 0 20rpx 20rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

/* 分类入口 */
.category-section {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
}

/* 创意推荐 */
.section {
  padding: 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.template-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx;
}

.template-item {
  width: calc(50% - 8rpx);
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.template-cover {
  width: 100%;
  height: 280rpx;
  background-color: #f0f0f0;
  display: block;
}

.template-info {
  padding: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.template-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-price {
  font-size: 26rpx;
  color: #FF6B6B;
  font-weight: bold;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 登录按钮（未登录状态） */
.login-only {
  width: 100%;
}

.login-only .login-tip-text {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  text-align: left;
}

.login-only .login-btn {
  width: 100%;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border: none;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 8rpx;
  padding: 16rpx 0;
}

.login-only .login-btn::after {
  border: none;
}
