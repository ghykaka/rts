/* pages/init-data/init-data.wxss */
.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
}

.btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}

.btn-secondary {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
}

.result {
  width: 80%;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.result.success {
  background: #e8f5e9;
  border: 2rpx solid #4caf50;
}

.result.error {
  background: #ffebee;
  border: 2rpx solid #f44336;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.result.success .result-title {
  color: #2e7d32;
}

.result.error .result-title {
  color: #c62828;
}

.result-msg {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.result-detail {
  font-size: 26rpx;
  color: #555;
}
