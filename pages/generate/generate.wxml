<!--pages/generate/generate.wxml-->
<view class="container">
  <!-- 顶部信息展示 -->
  <view class="header-info">
    <view class="info-row">
      <image class="product-image" src="{{productImage}}" mode="aspectFill" />
      <view class="plus-icon">+</view>
      <image class="template-cover" src="{{templateCover}}" mode="aspectFill" />
    </view>
    <view class="info-text">
      <text class="product-name">{{productName}}</text>
      <text class="template-style">{{templateName}}</text>
      <text class="template-desc" wx:if="{{templateDesc}}">{{templateDesc}}</text>
    </view>
  </view>

  <!-- 作品参考 -->
  <view class="section">
    <view class="section-title">作品参考</view>
    <scroll-view class="reference-scroll" scroll-x>
      <view class="reference-list">
        <image
          class="reference-item"
          src="{{templateCover}}"
          mode="aspectFill"
        />
      </view>
    </scroll-view>
  </view>

  <!-- 图片尺寸选择 -->
  <view class="section">
    <view class="section-title">图片尺寸</view>
    <view class="size-options">
      <view
        class="size-item {{selectedSize === '9:16' ? 'active' : ''}}"
        bindtap="selectSize"
        data-size="9:16"
      >
        <view class="size-preview" style="width: 40rpx; height: 72rpx;"></view>
        <text class="size-label">9:16</text>
      </view>
      <view
        class="size-item {{selectedSize === '3:4' ? 'active' : ''}}"
        bindtap="selectSize"
        data-size="3:4"
      >
        <view class="size-preview" style="width: 54rpx; height: 72rpx;"></view>
        <text class="size-label">3:4</text>
      </view>
      <view
        class="size-item {{selectedSize === '4:3' ? 'active' : ''}}"
        bindtap="selectSize"
        data-size="4:3"
      >
        <view class="size-preview" style="width: 72rpx; height: 54rpx;"></view>
        <text class="size-label">4:3</text>
      </view>
      <view
        class="size-item {{selectedSize === '1:1' ? 'active' : ''}}"
        bindtap="selectSize"
        data-size="1:1"
      >
        <view class="size-preview" style="width: 64rpx; height: 64rpx;"></view>
        <text class="size-label">1:1</text>
      </view>
    </view>
  </view>

  <!-- 表单输入 -->
  <view class="section form-section">
    <view class="form-item">
      <view class="form-label">价格文案</view>
      <input
        class="form-input"
        placeholder="请输入价格文案"
        value="{{priceText}}"
        bindinput="onPriceTextInput"
        maxlength="20"
      />
    </view>

    <view class="form-item">
      <view class="form-label">
        <text>自定义文案</text>
        <text class="char-count">{{customText.length}}/50</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="请输入自定义文案"
        value="{{customText}}"
        bindinput="onCustomTextInput"
        maxlength="50"
        auto-height
      />
    </view>

    <view class="form-item">
      <view class="form-label">个人专属二维码</view>
      <view class="upload-area" bindtap="uploadQrCode">
        <image
          wx:if="{{qrCodeUrl}}"
          class="upload-image"
          src="{{qrCodeUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">上传二维码</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 价格信息 -->
  <view class="price-info">
    <text class="price-label">消耗金额:</text>
    <text class="price-value">¥{{displayPrice}}</text>
    <text class="price-tip">(余额支付)</text>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-actions">
    <button class="generate-btn {{showSuccessTip ? 'disabled' : ''}}" bindtap="generate" disabled="{{generating || showSuccessTip}}">
      {{generating ? '生成中...' : showSuccessTip ? '已提交' : '立即生成'}}
    </button>
    
    <!-- 生成成功提示 -->
    <view class="success-tip" wx:if="{{showSuccessTip}}">
      <view class="success-content">
        <text class="success-text">生成任务已提交</text>
        <text class="success-desc">预计1-3分钟完成，请前往作品仓库查看</text>
        <view class="success-btn" bindtap="goToWorks">前往作品仓库</view>
      </view>
    </view>
    
    <view class="balance-tip" wx:if="{{!showSuccessTip}}">
      <text>当前余额: ¥{{displayBalance}}</text>
      <text class="recharge-link" bindtap="goRecharge">充值</text>
    </view>
  </view>
</view>
