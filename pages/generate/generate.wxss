/* pages/generate/generate.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 240rpx 0;  /* 顶部无边距 */
}

/* 功能主图（大图/头图）- 拉通顶部 */
.main-image-section {
  width: 100%;
  background: #fff;
  margin-bottom: 20rpx;  /* 与下方容器的间距 */
}

.main-image {
  width: 100%;
  display: block;
}

/* 通用区块样式 */
.section {
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

/* 参考样图 */
.reference-scroll {
  width: 100%;
  white-space: nowrap;
}

.reference-list {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.reference-item-wrap {
  flex-shrink: 0;
  width: 130rpx;
  height: 180rpx;
}

.reference-item {
  width: 130rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #eee;
  object-fit: contain;
}

/* 产品与模板区域 */
.product-template-section {
  padding: 24rpx 20rpx;
}

.product-template-content {
  display: flex;
  gap: 20rpx;
}

.image-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.image-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.product-image,
.template-cover {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
}

.placeholder-icon {
  font-size: 32rpx;
  color: #ccc;
}

.plus-icon {
  font-size: 36rpx;
  color: #999;
  font-weight: bold;
}

.info-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
}

/* 尺寸选择 - 横向排列，一行5个 */
.size-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.size-item {
  width: calc((100% - 48rpx) / 5);
  padding: 10rpx 4rpx;
  border-radius: 8rpx;
  border: 2rpx solid #eee;
  text-align: center;
  background: #fff;
  box-sizing: border-box;
  min-height: 120rpx;
}

.size-item.active {
  background: #FFF5F5;
  border-color: #D40E61;
}

.size-icon-wrap {
  width: 90rpx;
  height: 90rpx;
  margin: 0 auto 6rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.size-icon {
  width: 100%;
  height: 100%;
}

.size-icon-placeholder {
  width: 90rpx;
  height: 90rpx;
  margin: 0 auto 6rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 20rpx;
  color: #999;
}

.size-name {
  font-size: 22rpx;
  color: #333;
  font-weight: bold;
  line-height: 1.2;
}

.size-item.active .size-name {
  color: #D40E61;
}

.selected-size-desc {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.desc-label {
  color: #666;
}

.desc-value {
  color: #333;
}

/* 表单 */
.form-section {
  padding: 30rpx 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: auto;
}

.required-mark {
  color: #D40E61;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 图片上传区域 - 3列网格布局 */
.upload-grid-container {
  margin-bottom: 30rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.upload-area {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #f5f5f5;
  overflow: hidden;
}

.upload-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-icon {
  font-size: 48rpx;
  color: #ddd;
}

.upload-text {
  font-size: 22rpx;
  color: #999;
}

/* 支付方式 - 左右排列 */
.payment-section {
  padding: 30rpx 20rpx;
}

/* 个人用户布局 */
.payment-options {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

/* 企业用户布局 */
.payment-layout {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.payment-layout .payment-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

/* 企业用户：第二行子元素宽度 */
.payment-layout .payment-row > .payment-balance-item {
  flex: 1.2 !important;
}

.payment-layout .payment-row > .payment-cash-item {
  flex: 0.8 !important;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  background: #fff;
}

/* 个人用户：余额宽，单次付费窄 */
.payment-balance-item {
  flex: 1.2;
}

.payment-cash-item {
  flex: 0.8;
  position: relative;
}

/* 微信支付图标 */
.weixinpay-icon {
  width: 80rpx;
  height: 40rpx;
  margin-left: auto;
  margin-right: -10rpx;
  flex-shrink: 0;
}

/* 企业用户：企业余额拉通整行 */
.payment-layout > .payment-enterprise-item {
  width: 100% !important;
  flex: none !important;
  box-sizing: border-box;
}

.payment-item.active {
  border-color: #D40E61;
  background: #FFF5F5;
}

.payment-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.payment-item.active .payment-radio {
  border-color: #D40E61;
}

.radio-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #D40E61;
}

.payment-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.payment-label {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  margin-top: -5rpx;
}

.payment-price {
  font-size: 28rpx;
  color: #1252bb;
  margin-top: 5rpx;
}

.payment-balance {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  font-size: 22rpx;
  color: #999;
}

.recharge-btn {
  color: #D40E61;
  font-size: 22rpx;
}

/* 价格信息 */
.price-info {
  background: #fff;
  padding: 24rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #D40E61;
}

.price-num {
  font-size: 36rpx;
  color: #D40E61;
  font-weight: bold;
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.generate-btn[disabled] {
  background: #ddd;
}

.generate-btn.disabled {
  background: #ccc;
}

.generate-btn::after {
  border: none;
}

/* 生成成功提示 */
.success-tip {
  background: linear-gradient(135deg, #FFF5F5, #FFE8EC);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.success-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.success-text {
  font-size: 30rpx;
  color: #D40E61;
  font-weight: bold;
}

.success-desc {
  font-size: 24rpx;
  color: #666;
}

.success-btn {
  margin-top: 8rpx;
  padding: 16rpx 40rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
}
