/* pages/material-upload/material-upload.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.category-section,
.image-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 24rpx;
}

/* 分类选择器 */
.category-picker-wrapper {
  display: flex;
  height: 500rpx;
  border: 1rpx solid #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.category-picker-left,
.category-picker-right {
  flex: 1;
  height: 100%;
}

.category-picker-left {
  background-color: #f7f7f7;
  border-right: 1rpx solid #f5f5f5;
}

.picker-category-item {
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
}

.picker-category-item.active {
  color: #D40E61;
  background-color: #fff;
  font-weight: bold;
}

.category-picker-left .picker-category-item.active {
  background-color: #fff;
  border-left: 6rpx solid #D40E61;
}

.empty-picker {
  padding: 100rpx;
  font-size: 28rpx;
  color: #999;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selected-category-display {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.selected-category-label {
  color: #999;
  margin-right: 10rpx;
}

.selected-category-value {
  color: #333;
  font-weight: 500;
}

/* 图片选择 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.add-icon {
  font-size: 60rpx;
  color: #ddd;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.image-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 上传按钮 */
.upload-section {
  padding: 0 30rpx;
}

.upload-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border-radius: 44rpx;
  border: none;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn::after {
  border: none;
}

.upload-btn[disabled] {
  background: #ddd;
  color: #999;
}
