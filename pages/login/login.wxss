/* pages/login/login.wxss */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.btn-login {
  width: 600rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 40rpx;
  margin-bottom: 30rpx;
}

.btn-phone {
  width: 600rpx;
  background: linear-gradient(90deg, #D40E61, #FF5C8D);
  color: #fff;
  border-radius: 40rpx;
  margin-bottom: 30rpx;
}

.btn-phone::after {
  border: none;
}

.tip {
  color: #999;
  font-size: 24rpx;
}
