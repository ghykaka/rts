<!--pages/template-detail/template-detail.wxml-->
<view class="container">
  <view wx:if="{{template}}">
    <!-- 封面 -->
    <image class="cover" src="{{template.cover_url}}" mode="aspectFill" />
    
    <!-- 模板信息 -->
    <view class="info">
      <text class="name">{{template.name}}</text>
      <text class="desc">{{template.description}}</text>
    </view>

    <!-- 选择尺寸 -->
    <view class="section">
      <view class="section-title">选择尺寸</view>
      <view class="ratio-list">
        <view 
          class="ratio-item {{selectedRatio === item ? 'active' : ''}}"
          wx:for="{{ratios}}"
          wx:key="*this"
          bindtap="selectRatio"
          data-ratio="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 输入参数 -->
    <view class="section" wx:if="{{templateFields.length > 0}}">
      <view class="section-title">填写内容</view>
      <view class="field-list">
        <block wx:for="{{templateFields}}" wx:key="_id">
          <view class="field-item">
            <text class="field-label">{{item.field_label}}</text>
            <input 
              wx:if="{{item.field_type === 'text'}}"
              class="field-input"
              placeholder="{{item.field_label}}"
              bindinput="inputChange"
              data-key="{{item.field_name}}"
            />
            <textarea
              wx:if="{{item.field_type === 'textarea'}}"
              class="field-textarea"
              placeholder="{{item.field_label}}"
              bindinput="inputChange"
              data-key="{{item.field_name}}"
            />
            <view 
              wx:if="{{item.field_type === 'select'}}"
              class="field-select"
            >
              <picker mode="selector" range="{{item.options}}" bindchange="inputChange" data-key="{{item.field_name}}">
                <view class="picker">
                  选择{{item.field_label}}
                </view>
              </picker>
            </view>
            <view 
              wx:if="{{item.field_type === 'image'}}"
              class="field-image"
              bindtap="chooseImage"
              data-key="{{item.field_name}}"
            >
              <image wx:if="{{inputData[item.field_name]}}" src="{{inputData[item.field_name]}}" />
              <text wx:else>+</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 价格 -->
    <view class="price-info" wx:if="{{selectedPrice}}">
      <text class="price">¥{{selectedPrice.balance_price / 100}}</text>
    </view>

    <!-- 生成按钮 -->
    <view class="bottom-bar">
      <button 
        class="btn-generate" 
        bindtap="generate"
        loading="{{loading}}"
      >
        让她生！让她生！
      </button>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{!template}}">
    <text>加载中...</text>
  </view>
</view>
