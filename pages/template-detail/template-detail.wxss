/* pages/template-detail/template-detail.wxss */

.cover {
  width: 100%;
  height: 500rpx;
  background-color: #f5f5f5;
}

.info {
  padding: 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.ratio-list {
  display: flex;
  gap: 20rpx;
}

.ratio-item {
  padding: 16rpx 30rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.ratio-item.active {
  background-color: #07c160;
  color: #fff;
}

.field-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.field-item {
  display: flex;
  flex-direction: column;
}

.field-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.field-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.field-image {
  width: 150rpx;
  height: 150rpx;
  border: 1rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #999;
}

.field-image image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.price-info {
  padding: 30rpx;
  background-color: #fff;
  text-align: right;
}

.price {
  font-size: 36rpx;
  color: #ff6b35;
  font-weight: bold;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.btn-generate {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 40rpx;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
