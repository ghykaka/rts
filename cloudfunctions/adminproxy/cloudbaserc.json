{
  "version": "2.0",
  "envId": "liandaofutou-2gdayw0068d938b3",
  "functions": [
    {
      "name": "adminproxy",
      "timeout": 60,
      "memorySize": 256,
      "handler": "index.main",
      "runtime": "Nodejs18.15"
    }
  ],
  "trigger": {
    "adminproxy": {
      "name": "http-trigger",
      "type": "apigw",
      "config": {
        "auth": "NONE",
        "enableCORS": true,
        "isIntegratedResponse": true
      }
    }
  }
}
